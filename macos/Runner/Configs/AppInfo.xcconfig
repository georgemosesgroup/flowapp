// Application-level settings for the Runner target.

// The application's binary name. PRODUCT_NAME must stay as a valid
// identifier (no space) or Xcode's Info.plist substitution breaks.
// The user-facing window title is set by `CFBundleName` in Info.plist
// and by Flutter's `MaterialApp.title`.
PRODUCT_NAME = Flow

// The application's bundle identifier
PRODUCT_BUNDLE_IDENTIFIER = com.flow.mosesdev.desktop

// The copyright displayed in application information
PRODUCT_COPYRIGHT = Copyright © 2026 George Moses. All rights reserved.
